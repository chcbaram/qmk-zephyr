CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# 전력 — 지금까지 Zephyr/nRF 기본값에 얹혀 있었다. 기본값은 조용히 바뀔 수 있고
# 무선 키보드에선 이 세 줄이 전류를 좌우하므로 보드 차원에서 못 박는다. (ZMK 보드 관례와 동일)
#
# 이 보드에는 외부 32.768kHz 크리스탈(LFXO)이 있다. LFXO 는 내장 RC 대비 정확하고
# 주기적 캘리브레이션(HFCLK 기동)이 필요 없어 BLE idle 전력에 유리하다.
# ※ 크리스탈 없는 보드를 파생시킬 땐 반드시 K32SRC_RC 로 바꿔야 한다(안 그러면 LFCLK 미기동).
CONFIG_CLOCK_CONTROL_NRF_K32SRC_XTAL=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_50PPM=y

# DCDC 레귤레이터: LDO 대비 전류 크게 절감.
CONFIG_BOARD_ENABLE_DCDC=y
