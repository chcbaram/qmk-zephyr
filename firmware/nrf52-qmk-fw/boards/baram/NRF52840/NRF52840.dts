/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include "NRF52840-pinctrl.dtsi"
#include <zephyr/dt-bindings/dt-util.h>   // BIT() — sense-edge-mask 를 핀 번호로 쓰기 위해

/ {
	model = "NRF52840";
	compatible = "baram,NRF52840";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
    zephyr,console = &uart0;
	};

  leds {
    compatible = "gpio-leds";
    led: led_0 {
      gpios = <&gpio0 31 GPIO_ACTIVE_HIGH>;
      label = "LED";
    };
  };  

	usb_hid_kbd: hid_kbd {
		compatible = "zephyr,hid-device";
		label = "HID_KBD";
		protocol-code = "keyboard";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
	};  

	usb_hid_via: hid_via {
		compatible = "zephyr,hid-device";
		label = "HID_VIA";
		protocol-code = "none";
		in-report-size = <32>;
    out-report-size = <32>;
		in-polling-period-us = <1000>;
    out-polling-period-us = <1000>;
	};

	usb_hid_exk: hid_exk {
		compatible = "zephyr,hid-device";
		label = "HID_EXK";
		protocol-code = "none";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
  };

  /*
   * 키 매트릭스 — Zephyr 네이티브 gpio-kbd-matrix (input 서브시스템).
   * idle 시 전 컬럼 구동 + row 인터럽트 대기로 CPU sleep, 키 눌림에 wakeup (저전력).
   *
   * 명명 주의: Zephyr 는 row-gpios = "입력(인터럽트)", col-gpios = "구동 출력" 이다.
   * wish60 은 row2col 다이오드라 row 를 구동하고 col 을 읽으므로 역매핑한다:
   *   row-gpios(입력)  = wish60 col 0..14 (15개)  → QMK 의 col 인덱스
   *   col-gpios(출력)  = wish60 row 0..4  (5개)   → QMK 의 row 인덱스
   * 입력 15개라 CONFIG_INPUT_KBD_MATRIX_16_BIT_ROW=y 필요(기본 8비트는 8개 한도).
   *
   * 디바운스는 QMK(port/matrix.c 의 debounce())가 담당하므로 드라이버는 0(이중 디바운스 방지).
   */
  kbd_matrix: kbd-matrix {
    compatible = "gpio-kbd-matrix";

    row-gpios = <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* wish60 col0  */
                <&gpio1 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col1  */
                <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col2  */
                <&gpio1 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col3  */
                <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col4  */
                <&gpio0  3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col5  */
                <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col6  */
                <&gpio0 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col7  */
                <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col8  */
                <&gpio0 23 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col9  */
                <&gpio0 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col10 */
                <&gpio1  0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col11 */
                <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col12 */
                <&gpio0 25 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col13 */
                <&gpio1 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;   /* col14 */

    col-gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>,                      /* wish60 row0 */
                <&gpio0 14 GPIO_ACTIVE_HIGH>,                      /* row1 */
                <&gpio0 15 GPIO_ACTIVE_HIGH>,                      /* row2 */
                <&gpio0 16 GPIO_ACTIVE_HIGH>,                      /* row3 */
                <&gpio1  2 GPIO_ACTIVE_HIGH>;                      /* row4 */

    idle-mode = "interrupt";   /* 키 없을 때 인터럽트 대기 → CPU sleep */
    wakeup-source;             /* deep sleep(Phase 6)에서 wakeup 소스로 유지 */
    no-ghostkey-check;         /* 다이오드(row2col) 있으므로 고스팅 검사 불필요 */

    poll-period-ms   = <1>;    /* 키 눌린 동안 1kHz 재스캔 (USB 1ms 폴링 정합) */
    debounce-down-ms = <0>;    /* 디바운스는 QMK 가 담당 (이중 디바운스 방지) */
    debounce-up-ms   = <0>;
  };
};

&flash0 {
	/*
	 * wish60 기준 단일슬롯 레이아웃 (Adafruit nRF52 UF2 부트로더가 미리 플래시됨).
	 * MCUboot 듀얼슬롯(image-0/image-1)은 사용하지 않는다.
	 *   sd(MBR)   0x00000000  4KB
	 *   code      0x00001000  ~844KB   (앱, zephyr,code-partition)
	 *   storage   0x000d4000  128KB    (NVS/settings, emu-eeprom)
	 *   boot(UF2) 0x000f4000  48KB     (미리 들어있는 부트로더)
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		sd_partition: partition@0 {
			reg = <0x00000000 0x00001000>;
		};

		code_partition: partition@1000 {
			reg = <0x00001000 0x000d3000>;
		};

		/* QMK 키맵 영속화용 emu-eeprom 백엔드 (32KB = 8 페이지) */
		eeprom_partition: partition@d4000 {
			label = "eeprom";
			reg = <0x000d4000 0x00008000>;
		};

		/* 향후 NVS/settings (BLE bond 등, Phase 5) */
		storage_partition: partition@dc000 {
			label = "storage";
			reg = <0x000dc000 0x00018000>;
		};

		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
	};
};

/ {
	/* 플래시 에뮬레이션 EEPROM: QMK dynamic_keymap 의 바이트 주소 저장소.
	 * rambuf 로 읽기 속도 확보(키 조회 잦음). size 는 config.h TOTAL_EEPROM_BYTE_COUNT 와 일치.
	 */
	eeprom0: eeprom {
		compatible = "zephyr,emu-eeprom";
		size = <4096>;          /* 논리 EEPROM 크기 = config.h TOTAL_EEPROM_BYTE_COUNT */
		pagesize = <0x2000>;    /* 에뮬 페이지(=플래시 2페이지). size 보다 커야 함 */
		partition = <&eeprom_partition>;
		/* 전력 최적화:
		 *  - partition-erase: 파티션이 다 찰 때까지 erase 를 지연/통합 → 플래시 erase 횟수 최소.
		 *  - rambuf: 읽기를 RAM 에서 → 플래시 read 회피.
		 * (플래시 write 통합은 port/platforms/eeprom.c 의 디바운스 블록 flush 가 담당) */
		rambuf;
		partition-erase;
	};
};

/*
 * [중요] sense-edge-mask — kbd_matrix 의 row-gpios(입력 15개)를 모두 덮는다.
 *
 * Zephyr gpio-kbd-matrix 는 row 인터럽트를 GPIO_INT_EDGE_TO_ACTIVE(엣지)로 건다.
 * nRF 에서 엣지는 기본적으로 GPIOTE IN 채널을 쓰는데(gpio_nrfx.c), 두 가지 문제가 있다:
 *   1) nRF52840 의 GPIOTE 채널은 8개뿐인데 우리 입력은 15개 → 9번째부터 -ENOMEM.
 *      드라이버는 첫 실패에서 곧바로 return 해버려 뒤쪽 row 는 인터럽트가 아예 없다
 *      (= idle 에서 그 컬럼의 첫 키를 놓친다).
 *   2) GPIOTE 는 System OFF 에서 꺼진다 → deep sleep 에서 키로 못 깨어난다.
 *      System OFF 웨이크업은 오직 DETECT(PIN_CNF.SENSE) 로만 일어난다.
 *
 * sense-edge-mask 에 넣은 핀은 엣지라도 SENSE(PORT 이벤트)로 처리된다 → 채널 0개 + DETECT.
 * ZMK 는 kscan 에서 GPIO_INT_LEVEL_ACTIVE(레벨)를 써서 이 분기를 자동으로 타므로
 * 이 속성이 필요 없다. 네이티브 드라이버(엣지)를 택한 대가를 DTS 로 메우는 것.
 *
 * [수정법] 위 row-gpios 의 핀 번호를 그대로 BIT() 로 나열하면 된다(16진수 계산 불필요).
 * 빠뜨려도 조용히 깨지지 않는다 — port/matrix.c 의 BUILD_ASSERT 가 row-gpios 전 핀이
 * 마스크에 있는지 검사해서 **빌드를 막는다**. 핀을 바꾸면 빌드 에러가 알려준다.
 *   gpio0 row 핀: 3, 17, 20, 21, 22, 23, 24, 25
 */
&gpio0 {
  status = "okay";
  sense-edge-mask = <(BIT(3) | BIT(17) | BIT(20) | BIT(21) |
                      BIT(22) | BIT(23) | BIT(24) | BIT(25))>;
};

&gpiote {
  status = "okay";
};

// 배터리 잔량(VDDH). SAADC 내부 입력 VDDHDIV5 를 읽는다 — 외부 분압 저항 불필요.
// 배터리가 VDDH 핀에 직결된 고전압 모드가 전제다(일반 모드면 레귤레이터 출력을 읽는다).
// wish60 회로엔 i2c1 @0x36 에 MAX17048 도 있다 → 나중에 그 노드를 켜면 driver/battery.c 가
// 자동으로 연료게이지 백엔드로 전환한다(Zephyr 네이티브 maxim,max17048).
&adc {
  status = "okay";
};

&uart0 {
  status = "okay";
  pinctrl-0 = <&uart0_default>;
  pinctrl-1 = <&uart0_sleep>;
  pinctrl-names = "default", "sleep";
  compatible = "nordic,nrf-uarte";
  current-speed = <115200>;
};

// sense-edge-mask 근거는 &gpio0 주석 참고. gpio1 row 핀: 0, 10, 11, 12, 13, 14, 15
&gpio1 {
  status = "okay";
  sense-edge-mask = <(BIT(0) | BIT(10) | BIT(11) | BIT(12) |
                      BIT(13) | BIT(14) | BIT(15))>;
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	num-bidir-endpoints = <0>;
	num-in-endpoints = <7>;
	num-out-endpoints = <2>;
	num-isoin-endpoints = <0>;
	num-isoout-endpoints = <0>;
};
