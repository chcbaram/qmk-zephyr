/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include "NRF52840-pinctrl.dtsi"

/ {
	model = "NRF52840";
	compatible = "baram,NRF52840";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
    zephyr,console = &uart0;
	};

  leds {
    compatible = "gpio-leds";
    led: led_0 {
      gpios = <&gpio0 31 GPIO_ACTIVE_HIGH>;
      label = "LED";
    };
  };  

	usb_hid_kbd: hid_kbd {
		compatible = "zephyr,hid-device";
		label = "HID_KBD";
		protocol-code = "keyboard";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
	};  

	usb_hid_via: hid_via {
		compatible = "zephyr,hid-device";
		label = "HID_VIA";
		protocol-code = "none";
		in-report-size = <32>;
    out-report-size = <32>;
		in-polling-period-us = <1000>;
    out-polling-period-us = <1000>;
	};

	usb_hid_exk: hid_exk {
		compatible = "zephyr,hid-device";
		label = "HID_EXK";
		protocol-code = "none";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
  };

  keys {
		compatible = "gpio-leds";
		row0:  row_0  { gpios = <&gpio0 13 (GPIO_ACTIVE_HIGH)>; label = "row0";};     
		row1:  row_1  { gpios = <&gpio0 14 (GPIO_ACTIVE_HIGH)>; label = "row1";};     
		row2:  row_2  { gpios = <&gpio0 15 (GPIO_ACTIVE_HIGH)>; label = "row2";};     
		row3:  row_3  { gpios = <&gpio0 16 (GPIO_ACTIVE_HIGH)>; label = "row3";};     
    row4:  row_4  { gpios = <&gpio1  2 (GPIO_ACTIVE_HIGH)>; label = "row4";};         

    col0:  col_0  { gpios = <&gpio1 11 (GPIO_ACTIVE_HIGH)>; label = "col0";};     
    col1:  col_1  { gpios = <&gpio1 12 (GPIO_ACTIVE_HIGH)>; label = "col1";};     
    col2:  col_2  { gpios = <&gpio1 13 (GPIO_ACTIVE_HIGH)>; label = "col2";};     
    col3:  col_3  { gpios = <&gpio1 14 (GPIO_ACTIVE_HIGH)>; label = "col3";};     
    col4:  col_4  { gpios = <&gpio1 15 (GPIO_ACTIVE_HIGH)>; label = "col4";};     
    col5:  col_5  { gpios = <&gpio0  3 (GPIO_ACTIVE_HIGH)>; label = "col5";};     
    col6:  col_6  { gpios = <&gpio0 17 (GPIO_ACTIVE_HIGH)>; label = "col6";};     
    col7:  col_7  { gpios = <&gpio0 21 (GPIO_ACTIVE_HIGH)>; label = "col7";};     
    col8:  col_8  { gpios = <&gpio0 20 (GPIO_ACTIVE_HIGH)>; label = "col8";};      
    col9:  col_9  { gpios = <&gpio0 23 (GPIO_ACTIVE_HIGH)>; label = "col9";};     
    col10: col_10 { gpios = <&gpio0 22 (GPIO_ACTIVE_HIGH)>; label = "col10";};     
    col11: col_11 { gpios = <&gpio1  0 (GPIO_ACTIVE_HIGH)>; label = "col11";};       
    col12: col_12 { gpios = <&gpio0 24 (GPIO_ACTIVE_HIGH)>; label = "col12";};     
    col13: col_13 { gpios = <&gpio0 25 (GPIO_ACTIVE_HIGH)>; label = "col13";};          
    col14: col_14 { gpios = <&gpio1 10 (GPIO_ACTIVE_HIGH)>; label = "col14";};     
  };   
};

&flash0 {
	/*
	 * wish60 기준 단일슬롯 레이아웃 (Adafruit nRF52 UF2 부트로더가 미리 플래시됨).
	 * MCUboot 듀얼슬롯(image-0/image-1)은 사용하지 않는다.
	 *   sd(MBR)   0x00000000  4KB
	 *   code      0x00001000  ~844KB   (앱, zephyr,code-partition)
	 *   storage   0x000d4000  128KB    (NVS/settings, emu-eeprom)
	 *   boot(UF2) 0x000f4000  48KB     (미리 들어있는 부트로더)
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		sd_partition: partition@0 {
			reg = <0x00000000 0x00001000>;
		};

		code_partition: partition@1000 {
			reg = <0x00001000 0x000d3000>;
		};

		/* QMK 키맵 영속화용 emu-eeprom 백엔드 (32KB = 8 페이지) */
		eeprom_partition: partition@d4000 {
			label = "eeprom";
			reg = <0x000d4000 0x00008000>;
		};

		/* 향후 NVS/settings (BLE bond 등, Phase 5) */
		storage_partition: partition@dc000 {
			label = "storage";
			reg = <0x000dc000 0x00018000>;
		};

		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
	};
};

/ {
	/* 플래시 에뮬레이션 EEPROM: QMK dynamic_keymap 의 바이트 주소 저장소.
	 * rambuf 로 읽기 속도 확보(키 조회 잦음). size 는 config.h TOTAL_EEPROM_BYTE_COUNT 와 일치.
	 */
	eeprom0: eeprom {
		compatible = "zephyr,emu-eeprom";
		size = <4096>;          /* 논리 EEPROM 크기 = config.h TOTAL_EEPROM_BYTE_COUNT */
		pagesize = <0x2000>;    /* 에뮬 페이지(=플래시 2페이지). size 보다 커야 함 */
		partition = <&eeprom_partition>;
		/* 전력 최적화:
		 *  - partition-erase: 파티션이 다 찰 때까지 erase 를 지연/통합 → 플래시 erase 횟수 최소.
		 *  - rambuf: 읽기를 RAM 에서 → 플래시 read 회피.
		 * (플래시 write 통합은 port/platforms/eeprom.c 의 디바운스 블록 flush 가 담당) */
		rambuf;
		partition-erase;
	};
};

&gpio0 {
  status = "okay";
};

&gpiote {
  status = "okay";
};

&uart0 {
  status = "okay";
  pinctrl-0 = <&uart0_default>;
  pinctrl-1 = <&uart0_sleep>;
  pinctrl-names = "default", "sleep";
  compatible = "nordic,nrf-uarte";
  current-speed = <115200>;
};

&gpio1 {
  status = "okay";
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	num-bidir-endpoints = <0>;
	num-in-endpoints = <7>;
	num-out-endpoints = <2>;
	num-isoin-endpoints = <0>;
	num-isoout-endpoints = <0>;
};
