/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include "NRF52840-pinctrl.dtsi"
#include <zephyr/dt-bindings/dt-util.h>   // BIT()
#include <zephyr/dt-bindings/led/led.h>      // LED_COLOR_ID_* (ws2812 color-mapping)

/ {
	model = "NRF52840";
	compatible = "baram,NRF52840";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
    zephyr,console = &uart0;
	};

  leds {
    compatible = "gpio-leds";
    led: led_0 {
      gpios = <&gpio0 31 GPIO_ACTIVE_HIGH>;
      label = "LED";
    };
  };  

	usb_hid_kbd: hid_kbd {
		compatible = "zephyr,hid-device";
		label = "HID_KBD";
		protocol-code = "keyboard";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
	};  

	usb_hid_via: hid_via {
		compatible = "zephyr,hid-device";
		label = "HID_VIA";
		protocol-code = "none";
		in-report-size = <32>;
    out-report-size = <32>;
		in-polling-period-us = <1000>;
    out-polling-period-us = <1000>;
	};

	usb_hid_exk: hid_exk {
		compatible = "zephyr,hid-device";
		label = "HID_EXK";
		protocol-code = "none";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
  };

  /*
   * 키 매트릭스 — Zephyr 네이티브 gpio-kbd-matrix.
   *
   * [주의] Zephyr 명명은 반대다: row-gpios = 입력, col-gpios = 구동 출력.
   * wish60 은 row2col 이라 역매핑한다 — row-gpios = wish60 col(15), col-gpios = wish60 row(5).
   * 배경은 docs/PORTING-NOTES.md §2.4 참고.
   */
  /*
   * 네오픽셀 전원 레일 (wish60: P0.30).
   *
   * ZMK 는 zmk,ext-power-generic 이라는 자체 바인딩을 쓰지만, 이건 본질적으로 GPIO 로 켜고 끄는
   * 고정 레귤레이터라 Zephyr 네이티브 regulator-fixed 로 충분하다(regulator_enable/disable).
   * 흡수 코드 0 — kbd-matrix / MAX17048 과 같은 판단.
   *
   * wish60/wish65 둘 다 이 레일은 **네오픽셀만** 끊는다(595 는 상시 전원) — 확인됨.
   * regulator-boot-on 을 주지 않는다 = 부팅 시 꺼진 상태. RGB 를 켤 때만 올린다(전력).
   */
  ext_power: ext-power {
    compatible = "regulator-fixed";
    regulator-name = "ext-power";
    enable-gpios = <&gpio0 30 GPIO_ACTIVE_HIGH>;
    startup-delay-us = <1000>;   /* 레일이 올라올 시간. 바로 쓰면 첫 프레임이 깨진다 */
  };

  kbd_matrix: kbd-matrix {
    compatible = "gpio-kbd-matrix";

    row-gpios = <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* wish60 col0  */
                <&gpio1 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col1  */
                <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col2  */
                <&gpio1 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col3  */
                <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col4  */
                <&gpio0  3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col5  */
                <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col6  */
                <&gpio0 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col7  */
                <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col8  */
                <&gpio0 23 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col9  */
                <&gpio0 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col10 */
                <&gpio1  0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col11 */
                <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col12 */
                <&gpio0 25 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* col13 */
                <&gpio1 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;   /* col14 */

    col-gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>,                      /* wish60 row0 */
                <&gpio0 14 GPIO_ACTIVE_HIGH>,                      /* row1 */
                <&gpio0 15 GPIO_ACTIVE_HIGH>,                      /* row2 */
                <&gpio0 16 GPIO_ACTIVE_HIGH>,                      /* row3 */
                <&gpio1  2 GPIO_ACTIVE_HIGH>;                      /* row4 */

    idle-mode = "interrupt";   /* 키 없을 때 인터럽트 대기 → CPU sleep */
    wakeup-source;             /* deep sleep(Phase 6)에서 wakeup 소스로 유지 */
    no-ghostkey-check;         /* 다이오드(row2col) 있으므로 고스팅 검사 불필요 */

    /*
     * 키 눌린 동안 매트릭스 재스캔 주기. QMK 처리 주기(config.h 의 QMK_TASK_PERIOD_MS)와는
     * **별개 노브**다 — 같을 필요 없다. 둘 다 CPU 를 깨우므로 전력엔 둘 다 영향을 준다.
     * 실측/근거는 docs/PORTING-NOTES.md §6.4.
     */
    poll-period-ms   = <2>;    /* 키 변화 감지 지연 <=2ms, USB 리포트율 500Hz */
    debounce-down-ms = <0>;    /* 디바운스는 QMK 가 담당 (이중 디바운스 방지) */
    debounce-up-ms   = <0>;
  };
};

&flash0 {
	/*
	 * wish60 단일슬롯 레이아웃. UF2 부트로더가 미리 들어있다고 전제하고 앱만 빌드한다.
	 * 반드시 --no-sysbuild 로 빌드할 것(안 그러면 부팅 안 함). docs/PORTING-NOTES.md §2.2/§2.3.
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		sd_partition: partition@0 {
			reg = <0x00000000 0x00001000>;
		};

		code_partition: partition@1000 {
			reg = <0x00001000 0x000d3000>;
		};

		/* QMK 키맵 영속화용 emu-eeprom 백엔드 (32KB = 8 페이지) */
		eeprom_partition: partition@d4000 {
			label = "eeprom";
			reg = <0x000d4000 0x00008000>;
		};

		/* 향후 NVS/settings (BLE bond 등, Phase 5) */
		storage_partition: partition@dc000 {
			label = "storage";
			reg = <0x000dc000 0x00018000>;
		};

		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
	};
};

/ {
	/* QMK dynamic_keymap 저장소. size 는 config.h 의 TOTAL_EEPROM_BYTE_COUNT 와 일치시킬 것. */
	eeprom0: eeprom {
		compatible = "zephyr,emu-eeprom";
		size = <4096>;          /* 논리 EEPROM 크기 = config.h TOTAL_EEPROM_BYTE_COUNT */
		pagesize = <0x2000>;    /* 에뮬 페이지(=플래시 2페이지). size 보다 커야 함 */
		partition = <&eeprom_partition>;
		rambuf;             /* 읽기를 RAM 에서 → 플래시 read 회피 */
		partition-erase;    /* erase 지연·통합 → 플래시 erase 최소화 */
	};
};

/*
 * sense-edge-mask — row-gpios(입력) 핀을 그대로 BIT() 로 나열한다. 빠지면 빌드 에러
 * (port/matrix.c 의 BUILD_ASSERT). 이유는 docs/PORTING-NOTES.md §3.5 참고.
 */
&gpio0 {
  status = "okay";
  sense-edge-mask = <(BIT(3) | BIT(17) | BIT(20) | BIT(21) |
                      BIT(22) | BIT(23) | BIT(24) | BIT(25))>;
};

&gpiote {
  status = "okay";
};

/*
 * 배터리 잔량(VDDH) 측정용. MAX17048(i2c1 @0x36) 노드를 켜면 driver/battery.c 가 연료게이지
 * 백엔드로 자동 전환한다. docs/PORTING-NOTES.md §6.3 참고.
 */
&adc {
  status = "okay";
};

&uart0 {
  status = "okay";
  pinctrl-0 = <&uart0_default>;
  pinctrl-1 = <&uart0_sleep>;
  pinctrl-names = "default", "sleep";
  compatible = "nordic,nrf-uarte";
  current-speed = <115200>;
};

&gpio1 {
  status = "okay";
  sense-edge-mask = <(BIT(0) | BIT(10) | BIT(11) | BIT(12) |
                      BIT(13) | BIT(14) | BIT(15))>;
};

/*
 * 네오픽셀 — Zephyr 네이티브 worldsemi,ws2812-spi (SPIM MOSI 로 비트 패턴을 쏜다).
 * ZMK 도 같은 드라이버를 쓴다. 전원은 위 ext_power 레일이 공급한다.
 * 값(chain-length/color-mapping/frame)은 wish60 회로 기준.
 */
&spi3 {
  compatible = "nordic,nrf-spim";
  status = "okay";
  pinctrl-0 = <&spi3_default>;
  pinctrl-1 = <&spi3_sleep>;
  pinctrl-names = "default", "sleep";

  led_strip: ws2812@0 {
    compatible = "worldsemi,ws2812-spi";
    reg = <0>;                  /* SPI 바인딩상 필요하지만 CS 는 안 쓴다 */
    spi-max-frequency = <4000000>;

    chain-length = <16>;        /* wish60 언더글로우 LED 개수 */
    spi-one-frame = <0x70>;
    spi-zero-frame = <0x40>;
    color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
  };
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	num-bidir-endpoints = <0>;
	num-in-endpoints = <7>;
	num-out-endpoints = <2>;
	num-isoin-endpoints = <0>;
	num-isoout-endpoints = <0>;
};
