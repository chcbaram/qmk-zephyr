/dts-v1/;
#include <nordic/nrf52833_qiaa.dtsi>
#include "wish65-pinctrl.dtsi"
#include <zephyr/dt-bindings/dt-util.h>      // BIT()
#include <zephyr/dt-bindings/led/led.h>      // LED_COLOR_ID_* (ws2812 color-mapping)

/*
 * wish65 — 65% 배열, nRF52833.
 *
 * wish60 과의 차이(구조에 영향을 주는 것만):
 *  - **SoC 가 다르다**: nRF52833 (flash 512KB / RAM 128KB). wish60 은 nRF52840 (1MB/256KB).
 *  - **컬럼을 74HC595 두 개 직렬로 구동**한다(16핀). GPIO 부족 해결책.
 *  - **다이오드가 col2row** 라 매트릭스 방향이 wish60(row2col)과 **반대**다 — config.h 의
 *    MATRIX_DRIVE_IS_QMK_COL 참고. 595 는 읽기가 안 되니 반드시 구동측(col)에 있어야 하고,
 *    구동측이 col 이면 다이오드는 col2row 일 수밖에 없다. 구조적 귀결이다.
 *  - **디버그 LED 가 없다**(wish60 은 P0.31). Caps LED 는 P1.09 에 있다.
 *  - 네오픽셀 18개(wish60 은 16), ext-power P0.11(wish60 은 P0.30).
 */

/ {
	model = "wish65";
	compatible = "baram,wish65";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
		zephyr,console = &uart0;
	};

	/*
	 * **디버그 LED 가 없다** — wish60 은 P0.31 에 있지만 이 보드엔 그 부품이 없다(회로도 확인).
	 * 그래서 `leds` 노드를 두지 않는다 -> hw_def.h 의 DT_NODE_EXISTS 가 _USE_HW_LED 를 끄고,
	 * led.h 가 ledOn/ledOff/ledToSleep 을 no-op 매크로로 바꾼다. 공통 코드는 손댈 게 없다.
	 *
	 * 기판의 LED3(NCD0805R1)는 충전기(TP4054)의 CHRG 상태 표시라 MCU 가 구동하지 않는다.
	 */

	/*
	 * 키보드 인디케이터 LED — Caps Lock (P1.09).
	 * 회로: P1.09 -> R4(100) -> Q1(2N7002 NMOS) -> LED1(XL-3215UWC). 게이트 구동이므로 ACTIVE_HIGH.
	 * 사용처: keyboards/wish65/port/led_port.c 의 led_update_kb().
	 */
	indicator_leds {
		compatible = "gpio-leds";
		caps_led: led_0 {
			gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>;
			label = "CAPS_LED";
		};
	};

	usb_hid_kbd: hid_kbd {
		compatible = "zephyr,hid-device";
		label = "HID_KBD";
		protocol-code = "keyboard";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
	};

	usb_hid_via: hid_via {
		compatible = "zephyr,hid-device";
		label = "HID_VIA";
		protocol-code = "none";
		in-report-size = <32>;
		out-report-size = <32>;
		in-polling-period-us = <1000>;
		out-polling-period-us = <1000>;
	};

	usb_hid_exk: hid_exk {
		compatible = "zephyr,hid-device";
		label = "HID_EXK";
		protocol-code = "none";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
	};

	/*
	 * 네오픽셀 전원 레일 (wish65: P0.11).
	 * 이 레일은 **네오픽셀만** 끊는다 — 595 는 상시 전원이라 deep sleep 에서도 컬럼 구동이
	 * 유지된다(래치). 그래서 웨이크업이 성립한다. §4.2 참고.
	 * regulator-boot-on 없음 = 부팅 시 꺼진 상태. RGB 를 켤 때만 올린다.
	 */
	ext_power: ext-power {
		compatible = "regulator-fixed";
		regulator-name = "ext-power";
		enable-gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
		startup-delay-us = <1000>;
	};

	/*
	 * 키 매트릭스 — Zephyr 네이티브 gpio-kbd-matrix.
	 *
	 * Zephyr 명명: col-gpios = 구동 출력, row-gpios = 입력 라인.
	 * wish65 는 col2row 라 **구동(col-gpios) = QMK col = 595**, **입력(row-gpios) = QMK row**.
	 * wish60(row2col)과 반대다 — config.h 의 MATRIX_DRIVE_IS_QMK_COL 이 그걸 알린다.
	 */
	kbd_matrix: kbd-matrix {
		compatible = "gpio-kbd-matrix";

		/* 입력 = QMK row 5개 (진짜 MCU GPIO — 인터럽트 웨이크업이 여기 걸린다) */
		row-gpios = <&gpio0 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* row0 */
		            <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* row1 */
		            <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* row2 */
		            <&gpio0 30 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,   /* row3 */
		            <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;   /* row4 */

		/* 구동 = QMK col 16개 (595 두 개 직렬) */
		col-gpios = <&shift_reg  0 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  1 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  2 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  3 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  4 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  5 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  6 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  7 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  8 GPIO_ACTIVE_HIGH>,
		            <&shift_reg  9 GPIO_ACTIVE_HIGH>,
		            <&shift_reg 10 GPIO_ACTIVE_HIGH>,
		            <&shift_reg 11 GPIO_ACTIVE_HIGH>,
		            <&shift_reg 12 GPIO_ACTIVE_HIGH>,
		            <&shift_reg 13 GPIO_ACTIVE_HIGH>,
		            <&shift_reg 14 GPIO_ACTIVE_HIGH>,
		            <&shift_reg 15 GPIO_ACTIVE_HIGH>;

		idle-mode = "interrupt";   /* 키 없을 때 인터럽트 대기 → CPU sleep */
		wakeup-source;
		no-ghostkey-check;         /* 다이오드(col2row) 있으므로 고스팅 검사 불필요 */

		/*
		 * [주의] wish60(2ms)보다 느리게 잡았다. 컬럼 구동마다 **SPI 트랜잭션**이 일어나기
		 * 때문이다 — 16컬럼 × 500Hz = 8k SPI/초. wish60 은 GPIO 토글이라 공짜였다.
		 * 실측 후 조정할 것(§4.2 의 "SPI 비용" 항목). QMK 처리 주기와는 별개 노브다.
		 */
		poll-period-ms   = <4>;
		debounce-down-ms = <0>;    /* 디바운스는 QMK 가 담당 (이중 디바운스 방지) */
		debounce-up-ms   = <0>;
	};
};

&flash0 {
	/*
	 * wish65 단일슬롯 레이아웃 — **nRF52833 은 512KB** 라 wish60(1MB)과 다르다.
	 * UF2 부트로더가 0x74000 에 미리 들어있다고 전제한다(zmk-config 의 wish65 와 동일 위치).
	 * 반드시 --no-sysbuild 로 빌드할 것. §2.2/§2.3.
	 *
	 * ZMK 는 code 428KB / storage 32KB 로 잡았지만, 우리는 emu-eeprom(QMK 키맵)이 별도로
	 * 필요하므로 재배분했다. 현재 앱이 ~240KB 라 code 380KB 면 여유가 충분하다.
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		sd_partition: partition@0 {
			reg = <0x00000000 0x00001000>;
		};

		code_partition: partition@1000 {
			reg = <0x00001000 0x0005f000>;    /* 380KB */
		};

		/* QMK 키맵 영속화용 emu-eeprom 백엔드 (32KB) */
		eeprom_partition: partition@60000 {
			label = "eeprom";
			reg = <0x00060000 0x00008000>;
		};

		/* NVS/settings (BLE bond 등) */
		storage_partition: partition@68000 {
			label = "storage";
			reg = <0x00068000 0x0000c000>;    /* 48KB */
		};

		boot_partition: partition@74000 {
			reg = <0x00074000 0x0000c000>;    /* 48KB — 미리 들어있는 UF2 부트로더 */
		};
	};
};

/ {
	/* QMK dynamic_keymap 저장소. size 는 config.h 의 TOTAL_EEPROM_BYTE_COUNT 와 일치시킬 것. */
	eeprom0: eeprom {
		compatible = "zephyr,emu-eeprom";
		size = <4096>;
		pagesize = <0x2000>;
		partition = <&eeprom_partition>;
		rambuf;
		partition-erase;
	};
};

/*
 * sense-edge-mask — row-gpios(입력) 핀을 그대로 BIT() 로 나열한다. 빠지면 빌드 에러
 * (port/matrix.c 의 BUILD_ASSERT). deep sleep(System OFF)에서 GPIOTE 가 꺼지므로
 * DETECT/SENSE 로만 깨어날 수 있다. §3.5 참고.
 */
&gpio0 {
	status = "okay";
	sense-edge-mask = <(BIT(15) | BIT(17) | BIT(20) | BIT(30) | BIT(31))>;
};

&gpio1 {
	status = "okay";
};

&gpiote {
	status = "okay";
};

/* 배터리 잔량(VDDH). MAX17048 노드가 없으므로 driver/battery.c 가 VDDH ADC 로 간다. §6.3 */
&adc {
	status = "okay";
};

&uart0 {
	status = "okay";
	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
	compatible = "nordic,nrf-uarte";
	current-speed = <115200>;
};

/*
 * 74HC595 두 개 직렬 -> 16컬럼 구동. 드라이버: src/hw/driver/gpio_595.c (ZMK 이식).
 * CS 가 595 의 래치(RCLK)다 — SPI 전송이 끝나며 CS 가 올라갈 때 시프트된 값이 출력에 실린다.
 */
&spi2 {
	compatible = "nordic,nrf-spim";
	status = "okay";

	pinctrl-0 = <&spi2_default>;
	pinctrl-1 = <&spi2_sleep>;
	pinctrl-names = "default", "sleep";

	cs-gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;   /* 래치(RCLK) */

	shift_reg: gpio595@0 {
		compatible = "baram,gpio-595";
		status = "okay";
		gpio-controller;
		#gpio-cells = <2>;
		reg = <0>;
		ngpios = <16>;                   /* 595 2개 × 8 */
		spi-max-frequency = <2000000>;
	};
};

/*
 * 네오픽셀 — Zephyr 네이티브 worldsemi,ws2812-spi. 전원은 위 ext_power 레일이 공급한다.
 * 값(chain-length/color-mapping/frame)은 wish65 회로 기준.
 */
&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";

	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		spi-max-frequency = <4000000>;

		chain-length = <18>;        /* wish65 언더글로우 LED 개수 */
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
	};
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	num-bidir-endpoints = <0>;
	num-in-endpoints = <7>;
	num-out-endpoints = <2>;
	num-isoin-endpoints = <0>;
	num-isoout-endpoints = <0>;
};
