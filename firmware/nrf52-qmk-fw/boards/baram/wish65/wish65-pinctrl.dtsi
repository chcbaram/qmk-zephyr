&pinctrl {
  /*
   * [미확인] wish65 의 디버그 UART 배선을 확인하지 못했다 — zmk-config 의 wish65 는 UART 를
   * 정의하지 않는다. P0.06/P0.08 은 ZMK wish65 DTS 에서 쓰이지 않아 비어 있는 것으로 보여
   * 골랐다(nRF52 DK 관례 핀이기도 하다). 배포 빌드엔 콘솔이 없으므로 영향이 없지만,
   * -DDEBUG_CONSOLE=y 로 개발할 땐 **실제 배선과 맞는지 먼저 확인할 것**.
   */
  uart0_default: uart0_default {
    group1 {
      psels = <NRF_PSEL(UART_TX, 0, 6)>, <NRF_PSEL(UART_RX, 0, 8)>;
    };
  };

  uart0_sleep: uart0_sleep {
    group1 {
      psels = <NRF_PSEL(UART_TX, 0, 6)>;
    };
  };

  /* ws2812(네오픽셀) — SPIM MOSI 만 쓴다. wish65 회로: P0.29 */
  spi3_default: spi3_default {
    group1 {
      psels = <NRF_PSEL(SPIM_MOSI, 0, 29)>;
    };
  };

  spi3_sleep: spi3_sleep {
    group1 {
      psels = <NRF_PSEL(SPIM_MOSI, 0, 29)>;
      low-power-enable;
    };
  };

  /* 74HC595 시프트레지스터 2개 직렬 — SCK P0.03, MOSI P0.28 (래치/CS 는 아래 cs-gpios) */
  spi2_default: spi2_default {
    group1 {
      psels = <NRF_PSEL(SPIM_SCK, 0, 3)>,
              <NRF_PSEL(SPIM_MOSI, 0, 28)>;
    };
  };

  spi2_sleep: spi2_sleep {
    group1 {
      psels = <NRF_PSEL(SPIM_SCK, 0, 3)>,
              <NRF_PSEL(SPIM_MOSI, 0, 28)>;
      low-power-enable;
    };
  };
};
